# Copy to .env.local and fill in values. .env.local is gitignored.

# Neon Postgres (from Vercel Marketplace → Neon integration)
# Pooled connection string used by the app at runtime:
DATABASE_URL=

# Unpooled connection string used by drizzle-kit for migrations:
DATABASE_URL_UNPOOLED=

# Third-party book APIs
GOOGLE_BOOKS_API_KEY=
NYT_API_KEY=

# Shared secret for Vercel Cron calls to /api/cron/warm-nyt.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional: explicit public site URL (falls back to VERCEL_URL, then localhost)
# NEXT_PUBLIC_SITE_URL=https://bookworm-app.vercel.app
